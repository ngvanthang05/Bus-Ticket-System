# ---- REDIS ----
REDIS_PASSWORD=redis_secret_2024

# ---- POSTGRESQL - Auth Service ----
AUTH_DB_PASSWORD=auth_pass_2024

# ---- POSTGRESQL - Route Service ----
ROUTE_DB_PASSWORD=route_pass_2024

# ---- POSTGRESQL - Vehicle Service ----
VEHICLE_DB_PASSWORD=vehicle_pass_2024

# ---- POSTGRESQL - Trip Service ----
TRIP_DB_PASSWORD=trip_pass_2024

# ---- POSTGRESQL - Booking Service ----
BOOKING_DB_PASSWORD=booking_pass_2024

# ---- POSTGRESQL - Payment Service ----
PAYMENT_DB_PASSWORD=payment_pass_2024

# ---- POSTGRESQL - Notification Service ----
NOTIFICATION_DB_PASSWORD=notif_pass_2024

# ---- JWT ----
JWT_SECRET=bus-ticket-system-super-secret-key-change-in-production-2024
